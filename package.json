    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "4.3.1",
    "autoprefixer": "10.4.19",
    "gh-pages": "6.1.1",
    "object-hash": "3.0.0",
    "postcss": "8.4.38",
    "postcss-selector-parser": "^6.1.2",
    "tailwindcss": "3.4.3",
    "vite": "5.2.11"
  }
