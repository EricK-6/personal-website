{
  "name": "eric-kim-personal-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Personal CV / portfolio website for Dohyun (Eric) Kim",
  "scripts": {
    "copy-cv": "node scripts/copy-cv.mjs",
    "postinstall": "npm run copy-cv",
    "predev": "npm run copy-cv",
    "dev": "vite",
